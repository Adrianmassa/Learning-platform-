<!DOCTYPE html>
<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>學學星球 ✨ 二年級學習平台</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap');
 
:root {
  --sky: #6ECFF0;
  --sun: #FFD93D;
  --grass: #6BCB77;
  --coral: #FF6B6B;
  --lavender: #C3A6FF;
  --peach: #FFB347;
  --mint: #A8EDCA;
  --bg: #FFF9F0;
  --card: #FFFFFF;
  --text: #2D2D2D;
  --muted: #8A8A8A;
  --radius: 24px;
  --shadow: 0 8px 32px rgba(0,0,0,0.10);
  --shadow-sm: 0 4px 16px rgba(0,0,0,0.07);
}
 
* { box-sizing: border-box; margin: 0; padding: 0; }
 
body {
  font-family: 'Nunito', 'Noto Sans TC', sans-serif;
  background: var(--bg);
  min-height: 100vh;
  overflow-x: hidden;
  color: var(--text);
}
 
/* ── SCREEN MANAGER ── */
.screen { display: none; min-height: 100vh; flex-direction: column; }
.screen.active { display: flex; }
 
/* ── TOP BAR ── */
.topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16px 20px;
  background: white;
  box-shadow: 0 2px 12px rgba(0,0,0,0.06);
  position: sticky; top: 0; z-index: 100;
}
.topbar-back {
  width: 44px; height: 44px;
  border-radius: 50%;
  border: none;
  background: #F0F0F0;
  font-size: 20px;
  cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  transition: transform .15s;
}
.topbar-back:active { transform: scale(.9); }
.topbar-title { font-size: 18px; font-weight: 800; }
.topbar-stars {
  display: flex; align-items: center; gap: 4px;
  background: var(--sun);
  padding: 6px 14px;
  border-radius: 20px;
  font-weight: 800;
  font-size: 15px;
}
 
/* ── SCROLL CONTENT ── */
.content { flex: 1; overflow-y: auto; padding: 20px; }
 
/* ── BUTTONS ── */
.btn {
  display: flex; align-items: center; justify-content: center;
  gap: 10px;
  border: none; cursor: pointer;
  font-family: inherit;
  font-weight: 800;
  border-radius: 20px;
  transition: transform .15s, box-shadow .15s;
  user-select: none;
}
.btn:active { transform: scale(.96); }
.btn-lg {
  width: 100%; padding: 20px;
  font-size: 20px;
  border-radius: 24px;
}
.btn-md {
  padding: 14px 28px;
  font-size: 17px;
  border-radius: 18px;
}
.btn-sm {
  padding: 10px 20px;
  font-size: 14px;
  border-radius: 14px;
}
.btn-primary { background: var(--coral); color: white; box-shadow: 0 6px 0 #e04444; }
.btn-primary:active { box-shadow: 0 2px 0 #e04444; transform: translateY(4px) scale(.98); }
.btn-green { background: var(--grass); color: white; box-shadow: 0 6px 0 #4aaa58; }
.btn-green:active { box-shadow: 0 2px 0 #4aaa58; transform: translateY(4px) scale(.98); }
.btn-blue { background: var(--sky); color: white; box-shadow: 0 6px 0 #44aece; }
.btn-blue:active { box-shadow: 0 2px 0 #44aece; transform: translateY(4px) scale(.98); }
.btn-yellow { background: var(--sun); color: #333; box-shadow: 0 6px 0 #e0b800; }
.btn-yellow:active { box-shadow: 0 2px 0 #e0b800; transform: translateY(4px) scale(.98); }
.btn-purple { background: var(--lavender); color: white; box-shadow: 0 6px 0 #9c78e0; }
.btn-purple:active { box-shadow: 0 2px 0 #9c78e0; transform: translateY(4px) scale(.98); }
.btn-ghost { background: #F0F0F0; color: var(--text); box-shadow: 0 4px 0 #D0D0D0; }
.btn-ghost:active { box-shadow: 0 2px 0 #D0D0D0; transform: translateY(2px) scale(.98); }
.btn-disabled { background: #E0E0E0 !important; color: #AAA !important; box-shadow: none !important; cursor: not-allowed; pointer-events: none; }
 
/* ── CARD ── */
.card {
  background: var(--card);
  border-radius: var(--radius);
  box-shadow: var(--shadow-sm);
  padding: 20px;
  margin-bottom: 16px;
}
 
/* ── PROGRESS BAR ── */
.progress-wrap {
  background: #F0F0F0;
  border-radius: 12px;
  height: 14px;
  overflow: hidden;
  margin: 8px 0;
}
.progress-bar {
  height: 100%;
  border-radius: 12px;
  background: linear-gradient(90deg, var(--grass), var(--sky));
  transition: width .5s ease;
}
 
/* ── QUESTION COUNTER ── */
.q-counter {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 12px;
}
.q-dots {
  display: flex; gap: 6px;
}
.q-dot {
  width: 10px; height: 10px;
  border-radius: 50%;
  background: #E0E0E0;
  transition: background .3s;
}
.q-dot.done { background: var(--grass); }
.q-dot.current { background: var(--coral); transform: scale(1.3); }
 
/* ══════════════════════════════
   SCREEN 1: HOME
══════════════════════════════ */
#screen-home {
  background: linear-gradient(170deg, #E8F7FF 0%, #FFF9F0 60%);
}
.home-hero {
  padding: 30px 20px 10px;
  text-align: center;
}
.home-planet {
  font-size: 80px;
  animation: float 3s ease-in-out infinite;
  display: block;
  margin: 0 auto 10px;
}
@keyframes float {
  0%,100% { transform: translateY(0); }
  50% { transform: translateY(-12px); }
}
.home-title {
  font-size: 32px;
  font-weight: 900;
  color: var(--text);
  line-height: 1.2;
}
.home-sub {
  font-size: 16px;
  color: var(--muted);
  margin-top: 6px;
  font-weight: 600;
}
.home-stars-badge {
  display: inline-flex; align-items: center; gap: 6px;
  background: var(--sun);
  padding: 8px 20px;
  border-radius: 20px;
  font-weight: 900;
  font-size: 18px;
  margin: 16px auto 0;
}
.home-menu {
  padding: 20px;
  display: flex;
  flex-direction: column;
  gap: 14px;
}
.home-btn-card {
  border-radius: 24px;
  padding: 22px 20px;
  display: flex;
  align-items: center;
  gap: 16px;
  cursor: pointer;
  border: none;
  font-family: inherit;
  font-weight: 800;
  font-size: 20px;
  color: white;
  text-align: left;
  transition: transform .15s, box-shadow .15s;
  box-shadow: var(--shadow);
  width: 100%;
}
.home-btn-card:active { transform: scale(.97); }
.home-btn-card .icon { font-size: 40px; }
.hbc-1 { background: linear-gradient(135deg, #FF6B6B, #FF8E53); box-shadow: 0 8px 0 #c94040; }
.hbc-1:active { box-shadow: 0 3px 0 #c94040; transform: translateY(5px) scale(.98); }
.hbc-2 { background: linear-gradient(135deg, #6ECFF0, #43A8D0); box-shadow: 0 8px 0 #3088b0; }
.hbc-2:active { box-shadow: 0 3px 0 #3088b0; transform: translateY(5px) scale(.98); }
.hbc-3 { background: linear-gradient(135deg, #C3A6FF, #9B6FEF); box-shadow: 0 8px 0 #7a4fd0; }
.hbc-3:active { box-shadow: 0 3px 0 #7a4fd0; transform: translateY(5px) scale(.98); }
.home-btn-text { display: flex; flex-direction: column; }
.home-btn-text span:last-child { font-size: 14px; font-weight: 600; opacity: 0.85; margin-top: 2px; }
 
/* ══════════════════════════════
   SCREEN 2: SUBJECT
══════════════════════════════ */
.subject-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
}
.subject-card {
  border-radius: 24px;
  padding: 24px 16px;
  text-align: center;
  cursor: pointer;
  border: none;
  font-family: inherit;
  transition: transform .15s;
  box-shadow: var(--shadow);
}
.subject-card:active { transform: scale(.95); }
.subject-card .s-icon { font-size: 52px; display: block; margin-bottom: 10px; }
.subject-card .s-name { font-size: 20px; font-weight: 900; color: white; }
.subject-card .s-pub { font-size: 13px; font-weight: 600; color: rgba(255,255,255,0.8); margin-top: 4px; }
.sc-chinese { background: linear-gradient(135deg, #FF6B6B, #FF9A9A); box-shadow: 0 8px 0 #c94040; }
.sc-math { background: linear-gradient(135deg, #6ECFF0, #4AAFDF); box-shadow: 0 8px 0 #3088b0; }
.sc-locked { background: linear-gradient(135deg, #CCC, #AAA); box-shadow: 0 8px 0 #888; cursor: not-allowed; }
.sc-locked .s-name { color: white; }
.lock-chip {
  display: inline-block;
  background: rgba(0,0,0,0.15);
  color: white;
  font-size: 12px; font-weight: 700;
  padding: 4px 10px; border-radius: 10px;
  margin-top: 6px;
}
 
/* ══════════════════════════════
   SCREEN 3: UNIT LIST
══════════════════════════════ */
.unit-card {
  border-radius: 20px;
  padding: 18px 20px;
  margin-bottom: 14px;
  cursor: pointer;
  border: none;
  font-family: inherit;
  text-align: left;
  width: 100%;
  display: flex;
  align-items: center;
  gap: 16px;
  box-shadow: var(--shadow-sm);
  transition: transform .15s;
  background: white;
  border-left: 6px solid transparent;
}
.unit-card:active { transform: scale(.98); }
.unit-card.uc-active { border-left-color: var(--coral); }
.unit-card.uc-done { border-left-color: var(--grass); }
.unit-card.uc-locked { opacity: .5; cursor: not-allowed; }
.unit-num {
  width: 48px; height: 48px; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 20px; font-weight: 900; color: white;
  flex-shrink: 0;
}
.un-active { background: var(--coral); }
.un-done { background: var(--grass); }
.un-locked { background: #CCC; }
.unit-info { flex: 1; }
.unit-title { font-size: 18px; font-weight: 800; }
.unit-sub { font-size: 13px; color: var(--muted); margin-top: 3px; }
.unit-badges { display: flex; gap: 6px; margin-top: 8px; flex-wrap: wrap; }
.badge {
  padding: 4px 10px; border-radius: 10px;
  font-size: 12px; font-weight: 700;
}
.badge-done { background: #D4F5DB; color: #2e7d32; }
.badge-todo { background: #FFE8D6; color: #e65100; }
.badge-locked { background: #EEE; color: #888; }
 
/* ══════════════════════════════
   SCREEN 4-6: QUESTION ENGINE
══════════════════════════════ */
.qe-header {
  padding: 16px 20px 0;
}
.qe-mode-chip {
  display: inline-flex; align-items: center; gap: 6px;
  padding: 6px 14px; border-radius: 12px;
  font-size: 13px; font-weight: 700; color: white;
  margin-bottom: 10px;
}
.qe-mode-challenge { background: var(--coral); }
.qe-mode-reinforce { background: var(--peach); }
.qe-mode-explore { background: var(--lavender); }
 
.question-body {
  background: white;
  border-radius: 24px;
  padding: 28px 24px;
  margin: 0 0 16px;
  box-shadow: var(--shadow-sm);
  min-height: 200px;
}
.q-stem {
  font-size: 22px;
  font-weight: 800;
  line-height: 1.6;
  color: var(--text);
  margin-bottom: 20px;
}
.q-hint {
  font-size: 14px;
  color: var(--muted);
  margin-bottom: 16px;
  font-weight: 600;
}
 
/* Options */
.options-grid {
  display: flex; flex-direction: column; gap: 12px;
}
.option-btn {
  border: 3px solid #E8E8E8;
  background: white;
  border-radius: 18px;
  padding: 16px 20px;
  font-family: inherit;
  font-size: 19px;
  font-weight: 700;
  color: var(--text);
  cursor: pointer;
  text-align: left;
  display: flex; align-items: center; gap: 12px;
  transition: border-color .15s, background .15s, transform .1s;
}
.option-btn:active { transform: scale(.98); }
.option-btn.selected { border-color: var(--sky); background: #EDF7FF; }
.option-btn.correct { border-color: var(--grass); background: #EDFBF0; }
.option-btn.wrong { border-color: var(--coral); background: #FFF0F0; }
.option-letter {
  width: 34px; height: 34px; border-radius: 50%;
  background: #F0F0F0;
  display: flex; align-items: center; justify-content: center;
  font-size: 16px; font-weight: 900; flex-shrink: 0;
  transition: background .15s;
}
.selected .option-letter { background: var(--sky); color: white; }
.correct .option-letter { background: var(--grass); color: white; }
.wrong .option-letter { background: var(--coral); color: white; }
 
/* Fill blank */
.fill-input {
  width: 100%;
  border: 3px solid #E8E8E8;
  border-radius: 16px;
  padding: 16px 20px;
  font-family: inherit;
  font-size: 22px;
  font-weight: 700;
  color: var(--text);
  outline: none;
  margin-top: 10px;
  transition: border-color .15s;
}
.fill-input:focus { border-color: var(--sky); }
.fill-input.correct { border-color: var(--grass); background: #EDFBF0; }
.fill-input.wrong { border-color: var(--coral); background: #FFF0F0; }
 
/* Sentence building */
.sentence-chips {
  display: flex; flex-wrap: wrap; gap: 10px;
  margin: 12px 0;
}
.chip {
  padding: 10px 18px;
  border-radius: 14px;
  font-size: 18px; font-weight: 700;
  cursor: pointer;
  transition: transform .1s, opacity .1s;
  border: none;
  font-family: inherit;
}
.chip:active { transform: scale(.93); }
.chip-source { background: #EEE; color: var(--text); }
.chip-source.used { opacity: .3; pointer-events: none; }
.chip-answer { background: var(--sky); color: white; }
.chip-remove { background: var(--lavender); color: white; }
.sentence-answer-area {
  min-height: 56px;
  border: 3px dashed #D0D0D0;
  border-radius: 16px;
  padding: 10px 14px;
  display: flex; flex-wrap: wrap; gap: 8px;
  align-items: center;
  background: #FAFAFA;
  margin: 10px 0;
}
 
/* Handwrite task */
.handwrite-panel {
  background: linear-gradient(135deg, #FFF9E0, #FFFDF5);
  border: 3px dashed var(--sun);
  border-radius: 20px;
  padding: 24px;
  text-align: center;
}
.hw-icon { font-size: 56px; margin-bottom: 12px; }
.hw-title { font-size: 20px; font-weight: 900; margin-bottom: 8px; }
.hw-desc { font-size: 15px; color: var(--muted); font-weight: 600; line-height: 1.6; }
.hw-chars {
  display: flex; justify-content: center; gap: 16px;
  margin: 20px 0;
  flex-wrap: wrap;
}
.hw-char-box {
  width: 72px; height: 72px;
  border: 3px solid var(--sun);
  border-radius: 14px;
  background: white;
  display: flex; align-items: center; justify-content: center;
  font-size: 32px; font-weight: 900;
  box-shadow: 0 4px 12px rgba(255,217,61,0.2);
}
.hw-grid-hint {
  font-size: 13px; color: #AAA;
  margin-top: 6px; font-weight: 600;
}
 
/* Feedback */
.feedback-panel {
  border-radius: 20px;
  padding: 20px;
  margin-top: 10px;
}
.feedback-panel.correct { background: #EDFBF0; border: 2px solid var(--grass); }
.feedback-panel.wrong { background: #FFF0F0; border: 2px solid var(--coral); }
.feedback-panel.neutral { background: #F0F0FF; border: 2px solid var(--lavender); }
.feedback-icon { font-size: 36px; margin-bottom: 6px; }
.feedback-title { font-size: 18px; font-weight: 900; }
.feedback-text { font-size: 15px; color: var(--muted); margin-top: 6px; font-weight: 600; line-height: 1.6; }
 
/* ── Q footer buttons ── */
.q-footer {
  padding: 0 20px 24px;
  display: flex; flex-direction: column; gap: 12px;
}
 
/* ══════════════════════════════
   SCREEN 7: RESULT
══════════════════════════════ */
#screen-result {
  background: linear-gradient(160deg, #FFF0E0, #FFF9F0);
}
.result-hero {
  text-align: center;
  padding: 36px 20px 20px;
}
.result-emoji { font-size: 90px; animation: pop .5s ease-out; }
@keyframes pop {
  0% { transform: scale(0); opacity: 0; }
  70% { transform: scale(1.2); }
  100% { transform: scale(1); opacity: 1; }
}
.result-title { font-size: 30px; font-weight: 900; margin-top: 12px; }
.result-sub { font-size: 16px; color: var(--muted); font-weight: 600; margin-top: 6px; }
.result-score-card {
  background: white;
  border-radius: 28px;
  padding: 28px;
  margin: 0 20px;
  box-shadow: var(--shadow);
  display: flex;
  justify-content: space-around;
  align-items: center;
}
.score-item { text-align: center; }
.score-num { font-size: 42px; font-weight: 900; }
.score-label { font-size: 14px; color: var(--muted); font-weight: 600; margin-top: 4px; }
.score-divider { width: 2px; height: 60px; background: #EEE; }
.stars-earned {
  display: flex; justify-content: center; gap: 8px;
  margin: 20px 0;
}
.star-earned {
  font-size: 44px;
  animation: starPop .4s ease-out both;
}
@keyframes starPop {
  0% { transform: scale(0) rotate(-30deg); }
  70% { transform: scale(1.2) rotate(10deg); }
  100% { transform: scale(1) rotate(0); }
}
.star-earned:nth-child(2) { animation-delay: .15s; }
.star-earned:nth-child(3) { animation-delay: .3s; }
.result-msg {
  text-align: center;
  font-size: 18px; font-weight: 700;
  margin: 0 20px 20px;
  padding: 14px;
  background: white;
  border-radius: 16px;
  box-shadow: var(--shadow-sm);
}
 
/* ══════════════════════════════
   SCREEN 8: CLEAR (通關)
══════════════════════════════ */
#screen-clear {
  background: linear-gradient(160deg, #E8F7FF, #FFF9F0);
  text-align: center;
}
.clear-confetti {
  font-size: 100px;
  margin: 40px 0 10px;
  animation: spin .8s ease-out;
}
@keyframes spin {
  0% { transform: rotate(-20deg) scale(0); opacity: 0; }
  60% { transform: rotate(10deg) scale(1.15); }
  100% { transform: rotate(0) scale(1); opacity: 1; }
}
.clear-title { font-size: 34px; font-weight: 900; }
.clear-sub { font-size: 16px; color: var(--muted); font-weight: 600; margin: 8px 20px 0; }
.unlock-card {
  margin: 24px 20px;
  background: linear-gradient(135deg, #C3A6FF, #9B6FEF);
  border-radius: 24px;
  padding: 24px;
  color: white;
  box-shadow: 0 8px 0 #7a4fd0;
}
.unlock-icon { font-size: 52px; margin-bottom: 10px; }
.unlock-title { font-size: 22px; font-weight: 900; }
.unlock-sub { font-size: 15px; opacity: .85; font-weight: 600; margin-top: 6px; }
 
/* ══════════════════════════════
   SCREEN 9: EXPLORE
══════════════════════════════ */
#screen-explore {
  background: linear-gradient(160deg, #F0EBFF, #FFF9F0);
}
.explore-header {
  text-align: center;
  padding: 24px 20px 8px;
}
.explore-icon { font-size: 60px; }
.explore-title { font-size: 26px; font-weight: 900; margin-top: 8px; }
.explore-sub { font-size: 15px; color: var(--muted); font-weight: 600; margin-top: 4px; }
 
/* ══════════════════════════════
   SCREEN 10: PROGRESS
══════════════════════════════ */
.progress-hero {
  background: linear-gradient(135deg, var(--lavender), #9B6FEF);
  border-radius: 24px;
  padding: 24px;
  color: white;
  margin-bottom: 20px;
  text-align: center;
}
.progress-hero-stars { font-size: 48px; font-weight: 900; }
.progress-hero-label { font-size: 16px; opacity: .85; font-weight: 600; margin-top: 4px; }
.progress-section-title {
  font-size: 16px; font-weight: 800; color: var(--muted);
  margin-bottom: 12px; letter-spacing: .5px;
}
.achievement-grid {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 12px; margin-bottom: 20px;
}
.achievement-card {
  background: white; border-radius: 18px;
  padding: 16px; text-align: center;
  box-shadow: var(--shadow-sm);
}
.achievement-icon { font-size: 36px; margin-bottom: 6px; }
.achievement-label { font-size: 13px; font-weight: 700; color: var(--muted); }
.achievement-val { font-size: 22px; font-weight: 900; }
.unit-progress-card {
  background: white; border-radius: 20px;
  padding: 20px; margin-bottom: 12px;
  box-shadow: var(--shadow-sm);
}
.upc-header { display: flex; align-items: center; gap: 12px; margin-bottom: 12px; }
.upc-num {
  width: 44px; height: 44px; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 18px; font-weight: 900; color: white;
  flex-shrink: 0;
}
.upc-title { font-size: 17px; font-weight: 800; }
.upc-theme { font-size: 13px; color: var(--muted); font-weight: 600; margin-top: 2px; }
.mode-progress-row {
  display: flex; align-items: center; gap: 10px;
  margin-bottom: 8px;
}
.mode-label {
  width: 52px; font-size: 12px; font-weight: 700;
  padding: 4px 8px; border-radius: 8px; text-align: center; flex-shrink: 0;
}
.ml-challenge { background: #FFE8E8; color: #c94040; }
.ml-reinforce { background: #FFF0D6; color: #e65100; }
.ml-explore { background: #EEE8FF; color: #7a4fd0; }
.mode-pct { font-size: 12px; font-weight: 700; color: var(--muted); width: 36px; text-align: right; }
 
/* ── MISC ── */
.divider { height: 1px; background: #EEE; margin: 16px 0; }
.tag {
  display: inline-block;
  padding: 4px 12px; border-radius: 12px;
