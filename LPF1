// ─── NAV ─────────────────────────────────────────────────
function goTo(screenId) {
  state.screenHistory.push(state.currentScreen);
  showScreen(screenId);
}
 
function goBack() {
  const prev = state.screenHistory.pop();
  if (prev) showScreen(prev);
  else showScreen('screen-home');
}
 
function showScreen(id) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  state.currentScreen = id;
  updateStarDisplays();
 
  if (id === 'screen-progress') renderProgress();
}
 
function updateStarDisplays() {
  document.querySelectorAll('.star-display').forEach(el => el.textContent = state.totalStars);
  const homeEl = document.getElementById('home-total-stars');
  if (homeEl) homeEl.textContent = state.totalStars;
  const pEl = document.getElementById('progress-total-stars');
  if (pEl) pEl.textContent = state.totalStars;
}
 
function setReplayMode(v) { state.replayMode = v; }
 
function confirmQuit() {
  if (confirm('要離開這一關嗎？進度不會儲存喔！')) {
    goTo('screen-units');
  }
}
 
// ─── SUBJECT → UNITS ─────────────────────────────────────
function goToUnits(subject) {
  state.currentSubject = subject;
  const titleEl = document.getElementById('units-title');
  titleEl.textContent = subject === 'chinese' ? '國語單元' : '數學單元';
  renderUnitList(subject);
  goTo('screen-units');
}
 
function renderUnitList(subject) {
  const container = document.getElementById('units-list');
  const units = DB.units.filter(u => u.subject === subject);
  container.innerHTML = '';
 
  const tagClass = subject === 'chinese' ? 'tag-chinese' : 'tag-math';
  const tagLabel = subject === 'chinese' ? '國語' : '數學';
 
  units.forEach((unit, idx) => {
    const prog = state.unitProgress[unit.unit_id];
    const isFirst = idx === 0;
    const isUnlocked = idx === 0 || state.unitProgress[units[idx-1].unit_id]?.challenge;
 
    let numClass = isUnlocked ? (prog.challenge ? 'un-done' : 'un-active') : 'un-locked';
    let cardClass = isUnlocked ? (prog.challenge ? 'uc-done' : 'uc-active') : 'uc-locked';
    const numIcon = !isUnlocked ? '🔒' : prog.challenge ? '✓' : String(unit.lesson_order);
 
    let badgesHtml = '';
    const modes = [
      { key: 'challenge', label: '挑戰關' },
      { key: 'reinforcement', label: '補強關' },
      { key: 'exploration', label: '探索關' }
    ];
    modes.forEach(m => {
      if (!isUnlocked) {
        badgesHtml += `<span class="badge badge-locked">${m.label} 🔒</span>`;
      } else if (prog[m.key]) {
        badgesHtml += `<span class="badge badge-done">${m.label} ✓</span>`;
      } else {
        badgesHtml += `<span class="badge badge-todo">${m.label}</span>`;
      }
    });
 
    const onclick = isUnlocked ? `openUnit('${unit.unit_id}')` : `alert('請先完成前一課！')`;
 
    container.innerHTML += `
      <button class="unit-card ${cardClass}" onclick="${onclick}">
        <div class="unit-num ${numClass}">${numIcon}</div>
        <div class="unit-info">
          <div class="unit-title">第${unit.lesson_order}課　${unit.unit_title}</div>
          <div class="unit-sub"><span class="tag ${tagClass}">${tagLabel}</span> ．${unit.theme}</div>
          <div class="unit-badges">${badgesHtml}</div>
        </div>
      </button>`;
  });
}
 
// ─── OPEN UNIT → CHOOSE MODE ─────────────────────────────
function openUnit(unitId) {
  state.currentUnit = unitId;
  const unit = DB.units.find(u => u.unit_id === unitId);
  const prog = state.unitProgress[unitId];
 
  // Decide which mode to start
  if (!prog.challenge) {
    startMode('challenge');
  } else if (!prog.reinforcement) {
    startMode('reinforcement');
  } else if (!prog.exploration) {
    startMode('exploration');
  } else {
    // All done — offer replay
    const choice = confirm('你已經完成這一課了！要重新挑戰嗎？');
    if (choice) startMode('challenge');
  }
}
 
// ─── START MODE ──────────────────────────────────────────
function startMode(mode) {
  state.currentMode = mode;
  state.currentQuestions = DB.questions.filter(
    q => q.unit_id === state.currentUnit && q.mode_type === mode
  );
  state.currentQIndex = 0;
  state.correctCount = 0;
 
  const modeLabels = { challenge:'🎯 挑戰關', reinforcement:'💪 補強關', exploration:'🔭 探索關' };
  const modeClasses = { challenge:'qe-mode-challenge', reinforcement:'qe-mode-reinforce', exploration:'qe-mode-explore' };
 
  const chip = document.getElementById('q-mode-chip');
  chip.textContent = modeLabels[mode];
  chip.className = 'qe-mode-chip ' + modeClasses[mode];
 
  document.getElementById('q-topbar-title').textContent =
    mode === 'challenge' ? '挑戰關' : mode === 'reinforcement' ? '補強關' : '探索關';
 
  goTo('screen-question');
  renderQuestion();
}
 
// ─── RENDER QUESTION ─────────────────────────────────────
function renderQuestion() {
  const q = state.currentQuestions[state.currentQIndex];
  const total = state.currentQuestions.length;
  const idx = state.currentQIndex;
 
  state.answered = false;
  state.selectedOption = null;
  state.fillAnswer = '';
  state.handwriteDone = false;
 
  // counter
  document.getElementById('q-counter-text').textContent = `第 ${idx+1} / ${total} 題`;
  const pct = (idx / total) * 100;
  document.getElementById('q-progress-bar').style.width = pct + '%';
 
  // dots
  const dotsEl = document.getElementById('q-dots');
  dotsEl.innerHTML = '';
  for (let i = 0; i < total; i++) {
    const d = document.createElement('div');
    d.className = 'q-dot ' + (i < idx ? 'done' : i === idx ? 'current' : '');
    dotsEl.appendChild(d);
  }
 
  const container = document.getElementById('question-render');
  const footer = document.getElementById('q-footer');
  container.innerHTML = '';
  footer.innerHTML = '';
 
  if (q.question_type === 'single_choice' || q.question_type === 'sentence_choice') {
    renderSingleChoice(q, container, footer);
  } else if (q.question_type === 'fill_blank') {
    renderFillBlank(q, container, footer);
  } else if (q.question_type === 'writing_task') {
    renderHandwrite(q, container, footer);
  } else if (q.question_type === 'sentence_building') {
    renderSentenceBuilding(q, container, footer);
  }
}
 
// ── Single / Sentence Choice ──────────────────────────────
function renderSingleChoice(q, container, footer) {
  let optHtml = '';
  const letters = ['Ａ','Ｂ','Ｃ','Ｄ'];
  q.options.forEach((opt, i) => {
    optHtml += `
      <button class="option-btn" id="opt-${i}" onclick="selectOption(${i},'${escStr(opt)}','${escStr(q.answer)}')">
        <span class="option-letter">${letters[i]}</span>
        ${opt}
      </button>`;
  });
 
  container.innerHTML = `
    <div class="question-body">
      <div class="q-stem">${q.stem}</div>
      <div class="options-grid">${optHtml}</div>
      <div id="q-feedback" style="margin-top:12px;"></div>
    </div>`;
 
  footer.innerHTML = `<button class="btn btn-lg btn-primary btn-disabled" id="btn-next" onclick="nextQuestion()">下一題 →</button>`;
}
 
function selectOption(idx, val, answer) {
  if (state.answered) return;
  state.answered = true;
  state.selectedOption = val;
  const isCorrect = val === answer;
  if (isCorrect) state.correctCount++;
 
  document.querySelectorAll('.option-btn').forEach((btn, i) => {
    const opt = btn.querySelector('.option-letter').nextSibling.textContent.trim();
    if (opt === answer) btn.classList.add('correct');
    else if (i === idx && !isCorrect) btn.classList.add('wrong');
  });
 
  const fbEl = document.getElementById('q-feedback');
  if (isCorrect) {
    fbEl.innerHTML = `<div class="feedback-panel correct"><div class="feedback-icon">🎉</div><div class="feedback-title">答對了！</div><div class="feedback-text">${document.querySelector('#question-render .question-body').dataset.explanation || ''}</div></div>`;
  } else {
    const q = state.currentQuestions[state.currentQIndex];
    fbEl.innerHTML = `<div class="feedback-panel wrong"><div class="feedback-icon">🤔</div><div class="feedback-title">再想想…</div><div class="feedback-text">正確答案是「${answer}」<br>${q.explanation}</div></div>`;
  }
 
  // Store explanation on container for feedback
  container.querySelector('.question-body').dataset.explanation =
    state.currentQuestions[state.currentQIndex].explanation;
 
  // Re-render feedback with explanation
  if (isCorrect) {
    fbEl.innerHTML = `<div class="feedback-panel correct"><div class="feedback-icon">🎉</div><div class="feedback-title">答對了！</div><div class="feedback-text">${state.currentQuestions[state.currentQIndex].explanation}</div></div>`;
  }
 
  document.getElementById('btn-next').classList.remove('btn-disabled');
}
 
// ── Fill Blank ──────────────────────────────────────────
function renderFillBlank(q, container, footer) {
  container.innerHTML = `
    <div class="question-body">
      <div class="q-stem">${q.stem}</div>
      <input class="fill-input" id="fill-input" type="text" placeholder="在這裡填入答案" maxlength="10"
        oninput="state.fillAnswer=this.value" onkeydown="if(event.key==='Enter')submitFill()">
      <div id="q-feedback" style="margin-top:12px;"></div>
    </div>`;
 
  footer.innerHTML = `<button class="btn btn-lg btn-primary" onclick="submitFill()">確認答案 ✓</button>`;
}
 
function submitFill() {
  if (state.answered) return;
  const q = state.currentQuestions[state.currentQIndex];
  const val = document.getElementById('fill-input').value.trim();
  if (!val) { alert('請先填入答案喔！'); return; }
  state.answered = true;
  const isCorrect = val === q.answer;
  if (isCorrect) state.correctCount++;
 
  const inp = document.getElementById('fill-input');
  inp.classList.add(isCorrect ? 'correct' : 'wrong');
  inp.disabled = true;
 
  const fbEl = document.getElementById('q-feedback');
  if (isCorrect) {
    fbEl.innerHTML = `<div class="feedback-panel correct"><div class="feedback-icon">🎉</div><div class="feedback-title">答對了！</div><div class="feedback-text">${q.explanation}</div></div>`;
  } else {
    fbEl.innerHTML = `<div class="feedback-panel wrong"><div class="feedback-icon">🤔</div><div class="feedback-title">再想想…</div><div class="feedback-text">正確答案是「${q.answer}」<br>${q.explanation}</div></div>`;
  }
 
  document.getElementById('q-footer').innerHTML = `<button class="btn btn-lg btn-primary" onclick="nextQuestion()">下一題 →</button>`;
}
 
// ── Handwrite Task ──────────────────────────────────────
function renderHandwrite(q, container, footer) {
  // Show chars to write if applicable
  let charsHtml = '';
  if (q.answer && q.answer !== '（開放式，參考：春天的花朵像笑臉）') {
    charsHtml = '<div class="hw-chars">';
    [...q.answer].forEach(ch => {
      charsHtml += `<div><div class="hw-char-box">${ch}</div><div class="hw-grid-hint">⬜</div></div>`;
    });
    charsHtml += '</div>';
  } else {
    // Open-ended: show the stem as writing guide
    charsHtml = `<div style="margin:16px 0; padding:16px; background:white; border-radius:16px; font-size:19px; font-weight:700; color:#555; text-align:center; border: 2px solid #FFD93D;">春天的______像______</div>`;
  }
 
  container.innerHTML = `
    <div class="question-body">
      <div class="q-stem" style="font-size:19px;">${q.stem}</div>
      <div class="handwrite-panel">
        <div class="hw-icon">✍️</div>
        <div class="hw-title">先在紙上寫 / 算！</div>
        <div class="hw-desc">拿出鉛筆和紙，在格子紙上練習寫出下面的字：</div>
        ${charsHtml}
        <div class="hw-desc" style="color:#AAA;font-size:13px;">寫好了再按「我寫好了」</div>
      </div>
      <div id="q-feedback" style="margin-top:12px;"></div>
    </div>`;
 
  footer.innerHTML = `<button class="btn btn-lg btn-yellow" onclick="confirmHandwrite()">✅ 我寫好了！</button>`;
}
 
function confirmHandwrite() {
  state.handwriteDone = true;
  state.answered = true;
  state.correctCount++; // Handwrite always "passes" in v1
 
  const q = state.currentQuestions[state.currentQIndex];
  const fbEl = document.getElementById('q-feedback');
  fbEl.innerHTML = `
    <div class="feedback-panel neutral">
      <div class="feedback-icon">✨</div>
      <div class="feedback-title">寫完了！很棒！</div>
      <div class="feedback-text">${q.explanation}</div>
    </div>`;
 
  document.getElementById('q-footer').innerHTML = `<button class="btn btn-lg btn-green" onclick="nextQuestion()">繼續 →</button>`;
}
 
// ── Sentence Building ───────────────────────────────────
function renderSentenceBuilding(q, container, footer) {
  state.sentencePool = [...q.options];
  state.sentenceBuilt = [];
 
  container.innerHTML = `
    <div class="question-body">
      <div class="q-stem">${q.stem}</div>
      <div class="q-hint">點一下詞語來排列句子 👇</div>
      <div class="sentence-answer-area" id="sb-answer"></div>
      <div class="sentence-chips" id="sb-pool">
        ${q.options.map((opt,i) => `<button class="chip chip-source" id="chip-${i}" onclick="addChip(${i},'${escStr(opt)}')">${opt}</button>`).join('')}
      </div>
      <div id="q-feedback" style="margin-top:12px;"></div>
    </div>`;
 
  footer.innerHTML = `
    <button class="btn btn-lg btn-primary" onclick="submitSentence('${escStr(q.answer)}')">確認答案 ✓</button>
    <button class="btn btn-sm btn-ghost" onclick="clearSentence()">清除重排</button>`;
}
 
function addChip(idx, val) {
  const chipEl = document.getElementById('chip-'+idx);
  if (chipEl.classList.contains('used')) return;
  chipEl.classList.add('used');
  state.sentenceBuilt.push({ idx, val });
  renderBuiltSentence();
}
 
function renderBuiltSentence() {
  const area = document.getElementById('sb-answer');
  if (!area) return;
  area.innerHTML = '';
  if (state.sentenceBuilt.length === 0) {
    area.innerHTML = '<span style="color:#CCC;font-size:15px;font-weight:600;">點詞語來組句子</span>';
    return;
  }
  state.sentenceBuilt.forEach((item, i) => {
    const btn = document.createElement('button');
    btn.className = 'chip chip-remove';
    btn.textContent = item.val;
    btn.onclick = () => removeChip(i);
    area.appendChild(btn);
  });
}
 
function removeChip(builtIdx) {
  const removed = state.sentenceBuilt.splice(builtIdx, 1)[0];
  document.getElementById('chip-'+removed.idx).classList.remove('used');
  renderBuiltSentence();
}
 
function clearSentence() {
  state.sentenceBuilt.forEach(item => {
    const el = document.getElementById('chip-'+item.idx);
    if (el) el.classList.remove('used');
  });
  state.sentenceBuilt = [];
  renderBuiltSentence();
}
 
function submitSentence(answer) {
  if (state.answered) return;
  const built = state.sentenceBuilt.map(i => i.val).join('');
  if (!built) { alert('請先排列詞語喔！'); return; }
  state.answered = true;
  const isCorrect = built === answer;
  if (isCorrect) state.correctCount++;
 
  const fbEl = document.getElementById('q-feedback');
  const q = state.currentQuestions[state.currentQIndex];
  if (isCorrect) {
    fbEl.innerHTML = `<div class="feedback-panel correct"><div class="feedback-icon">🎉</div><div class="feedback-title">答對了！</div><div class="feedback-text">${q.explanation}</div></div>`;
  } else {
    fbEl.innerHTML = `<div class="feedback-panel wrong"><div class="feedback-icon">🤔</div><div class="feedback-title">再想想…</div><div class="feedback-text">正確答案是「${answer}」<br>${q.explanation}</div></div>`;
  }
  document.getElementById('q-footer').innerHTML = `<button class="btn btn-lg btn-primary" onclick="nextQuestion()">下一題 →</button>`;
}
 
// ── Next Question / End ─────────────────────────────────
function nextQuestion() {
  state.currentQIndex++;
  if (state.currentQIndex >= state.currentQuestions.length) {
    endMode();
  } else {
    renderQuestion();
  }
}
 
function endMode() {
  const mode = state.currentMode;
  const prog = state.unitProgress[state.currentUnit];
 
  if (mode === 'challenge') {
    prog.challenge = true;
    prog.challengeScore = state.correctCount;
    const earned = Math.min(5, Math.ceil((state.correctCount / state.currentQuestions.length) * 5));
    prog.starsEarned = earned;
    state.totalStars += earned;
    showResult();
  } else if (mode === 'reinforcement') {
    prog.reinforcement = true;
    state.totalStars += 3;
    showClear();
  } else if (mode === 'exploration') {
    prog.exploration = true;
    state.totalStars += 5;
    showExploreDone();
  }
  updateStarDisplays();
}
 
// ─── RESULT SCREEN ───────────────────────────────────────
function showResult() {
  const total = state.currentQuestions.length;
  const correct = state.correctCount;
  const pct = correct / total;
  const prog = state.unitProgress[state.currentUnit];
  const stars = prog.starsEarned;
 
  const titles = pct === 1 ? ['🤩', '全對！你是小天才！'] :
                 pct >= 0.6 ? ['🎉', '做得很好！'] :
                              ['😊', '繼續加油！'];
 
  document.getElementById('result-emoji').textContent = titles[0];
  document.getElementById('result-title').textContent = titles[1];
  document.getElementById('result-sub').textContent = `完成挑戰關！答對 ${correct}/${total} 題`;
  document.getElementById('result-correct').textContent = correct;
  document.getElementById('result-total').textContent = total;
  document.getElementById('result-stars-earned').textContent = `+${stars}⭐`;
 
  const starsEl = document.getElementById('result-stars-display');
  starsEl.innerHTML = Array(stars).fill('<span class="star-earned">⭐</span>').join('') +
    Array(5-stars).fill('<span class="star-earned" style="opacity:.2">⭐</span>').join('');
 
  const msgs = pct === 1 ? '超厲害！完美的成績！繼續去補強關吧！' :
               pct >= 0.6 ? '不錯喔！再去補強關練練看吧！' :
                            '沒關係！去補強關多練習幾次！';
  document.getElementById('result-msg').textContent = msgs;
 
  state.screenHistory = []; // clear so back doesn't go to question
  goTo('screen-result');
}
 
function startReinforce() {
  startMode('reinforcement');
}
 
// ─── CLEAR SCREEN ────────────────────────────────────────
function showClear() {
  state.screenHistory = [];
  goTo('screen-clear');
}
 
function startExplore() {
  startMode('exploration');
}
 
// ─── EXPLORE DONE ────────────────────────────────────────
function showExploreDone() {
  const unit = DB.units.find(u => u.unit_id === state.currentUnit);
  // Show a completion message inline in explore screen
  const container = document.getElementById('question-render');
  const footer = document.getElementById('q-footer');
  if (container) {
    container.innerHTML = `
      <div class="question-body" style="text-align:center; padding:40px 24px;">
        <div style="font-size:72px; margin-bottom:16px;">🌟</div>
        <div style="font-size:26px; font-weight:900; margin-bottom:12px;">探索完成！</div>
        <div style="font-size:16px; color:var(--muted); font-weight:600; line-height:1.8;">
          你完成了《${unit.unit_title}》的所有關卡！<br>
          獲得 +5⭐ 星星！
        </div>
      </div>`;
    footer.innerHTML = `
      <button class="btn btn-lg btn-purple" onclick="goTo('screen-units')">🏠 回到單元列表</button>
      <button class="btn btn-lg btn-ghost" onclick="goTo('screen-progress')">📊 看我的進度</button>`;
  }
}
 
// ─── PROGRESS SCREEN ─────────────────────────────────────
function renderProgress() {
  const allProg = Object.values(state.unitProgress);
  document.getElementById('ach-challenge').textContent = allProg.filter(p=>p.challenge).length;
  document.getElementById('ach-reinforce').textContent = allProg.filter(p=>p.reinforcement).length;
  document.getElementById('ach-explore').textContent = allProg.filter(p=>p.exploration).length;
 
  let hwCount = 0;
  // Rough estimate: each completed challenge/reinforce may have handwrite tasks
  DB.questions.filter(q=>q.question_type==='writing_task').forEach(q => {
    const prog = state.unitProgress[q.unit_id];
    if (prog && (prog.challenge || prog.reinforcement || prog.exploration)) hwCount++;
  });
  document.getElementById('ach-handwrite').textContent = hwCount;
 
  const container = document.getElementById('progress-unit-list');
  container.innerHTML = '';
  DB.units.filter(u => u.subject === 'chinese').forEach((unit, idx) => {
    const prog = state.unitProgress[unit.unit_id];
    const colors = ['#FF6B6B','#6ECFF0','#6BCB77'];
    const color = colors[idx % colors.length];
 
    const modes = [
      { key:'challenge', label:'挑戰', cls:'ml-challenge' },
      { key:'reinforcement', label:'補強', cls:'ml-reinforce' },
      { key:'exploration', label:'探索', cls:'ml-explore' }
    ];
 
    let modesHtml = modes.map(m => {
      const done = prog[m.key];
      const pct = done ? 100 : 0;
      return `<div class="mode-progress-row">
        <span class="mode-label ${m.cls}">${m.label}</span>
        <div class="progress-wrap" style="flex:1;height:10px;margin:0;">
          <div class="progress-bar" style="width:${pct}%;background:${m.key==='challenge'?'var(--coral)':m.key==='reinforcement'?'var(--peach)':'var(--lavender)'}"></div>
        </div>
        <span class="mode-pct">${pct}%</span>
      </div>`;
    }).join('');
 
    container.innerHTML += `
      <div class="unit-progress-card">
        <div class="upc-header">
          <div class="upc-num" style="background:${color}">${unit.lesson_order}</div>
          <div>
            <div class="upc-title">${unit.unit_title}</div>
            <div class="upc-theme">${unit.theme}</div>
          </div>
          <div style="margin-left:auto;font-weight:900;color:var(--sun)">
            ${prog.starsEarned > 0 ? '⭐'.repeat(prog.starsEarned) : '—'}
          </div>
        </div>
        ${modesHtml}
      </div>`;
  });
}
 
// ─── UTIL ────────────────────────────────────────────────
function escStr(str) {
  return (str||'').replace(/'/g, "\\'");
}
 
// Init
updateStarDisplays();
</script>
</body>
</html>